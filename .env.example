# OpenRouter API Configuration (REQUIRED for AI suggestions)
# Powers the AI pattern generation — e.g. "(animals)" → dog, tiger, wolf.
# Without it, only literal slash patterns like "(com/io)" work.
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# OpenRouter model override (OPTIONAL)
# Any model that supports structured outputs works. See https://openrouter.ai/models
# Default: google/gemini-3.5-flash  •  Cheaper: google/gemini-3.1-flash-lite
# OPENROUTER_MODEL=google/gemini-3.5-flash

# Domainr API Configuration (OPTIONAL)
# Used only as a final fallback for availability checks. RDAP + WHOIS cover most
# TLDs without it; add it to improve accuracy on TLDs those miss.
# Get your key from: https://rapidapi.com/domainr/api/domainr
DOMAINR_RAPIDAPI_KEY=your_rapidapi_key_here

# PostHog Analytics Configuration (OPTIONAL)
# Used for event tracking and product analytics.
# Get your key from: https://posthog.com
# Leave blank to disable analytics.
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
